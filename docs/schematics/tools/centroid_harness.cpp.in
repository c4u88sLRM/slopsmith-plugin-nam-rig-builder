#include <cmath>
#include <cstdio>
#include <cstdlib>
#include <vector>
#include "@PLUGIN_CPP@"
START_NAMESPACE_DISTRHO
struct Probe : public @CLASS@ {
    void setP(uint32_t i,float v){ setParameterValue(i,v);} 
    float getP(uint32_t i)const{ return getParameterValue(i);} 
    void sr(double s){ sampleRateChanged(s);} void act(){ activate();} 
    void go(const float**in,float**out,uint32_t n){ run(in,out,n);} 
};
END_NAMESPACE_DISTRHO
using DISTRHO::Probe;
static const double SR=48000.0; static const int WARM=24000, N=240000; static const uint32_t CH=512;
int main(int argc,char**argv){
    if(argc<2){fprintf(stderr,"usage: probe out.f32\n");return 2;}
    Probe p; p.sr(SR); p.act();
    int np=(int)kParamCount; for(int i=0;i<np;i++) p.setP((uint32_t)i,p.getP((uint32_t)i)); // defaults
    // deterministic white noise, RMS ~0.05 (guitar-ish DI level)
    uint32_t st=2463534242u; auto rng=[&](){ st^=st<<13; st^=st>>17; st^=st<<5; return ((int32_t)st)/2147483648.0f; };
    FILE*fo=fopen(argv[1],"wb");
    float inL[CH],inR[CH],outL[CH],outR[CH]; const float*ins[2]={inL,inR}; float*outs[2]={outL,outR};
    int pos=0; int total=WARM+N;
    while(pos<total){ uint32_t f=(uint32_t)std::min((int)CH,total-pos);
        for(uint32_t i=0;i<f;i++){ float x=rng()*0.05f; inL[i]=inR[i]=x; }
        p.go(ins,outs,f);
        for(uint32_t i=0;i<f;i++) if(pos+(int)i>=WARM) fwrite(&outL[i],4,1,fo);
        pos+=f; }
    fclose(fo); return 0;
}
